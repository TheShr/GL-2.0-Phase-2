# Mappls (MapmyIndia) Access Token (Used on client and server)
NEXT_PUBLIC_MAPPLS_TOKEN=your_mappls_token_here
MAPPLS_TOKEN=your_mappls_token_here

# Groq API Key (Used on server)
GROQ_API_KEY=your_groq_api_key_here

# Configurable path to backend GNN output directory (defaults to ../backend/output if not specified)
BACKEND_OUTPUT_DIR=../backend/output
